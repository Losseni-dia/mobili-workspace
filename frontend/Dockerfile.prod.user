# --- ÉTAPE 1 : Build ---
FROM node:22-alpine AS builder
WORKDIR /app

# On déclare l'argument de build (comme ton prof avec VITE_API_BASE_URL)
ARG MOBILI_API_BASE_URL

# Installation des dépendances
COPY package*.json ./
RUN npm ci

# Copie du code source
COPY . .

# --- LA TOUCHE MAGIQUE ---
# On remplace le placeholder dans index.html par l'URL du Load Balancer
# On utilise || true pour éviter que le build plante si le fichier est introuvable
RUN sed -i "s|__MOBILI_API_BASE_URL__|${MOBILI_API_BASE_URL}|g" src/index.html

# Compilation production (le flag --configuration production masque tes logs de succès)
RUN npx ng build --configuration production

# --- ÉTAPE 2 : Serveur de Production ---
FROM nginx:alpine

# Récupération du build
COPY --from=builder /app/dist/frontend/browser /usr/share/nginx/html

# Configuration Nginx (gestion des routes Angular)
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]