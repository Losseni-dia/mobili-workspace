{
  "family": "td-mobili-backend-staging",
  "executionRoleArn": "arn:aws:iam::420943511896:role/ecsTaskExecutionRole",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "512",
  "memory": "1024",
  "containerDefinitions": [
    {
      "name": "mobili-backend",
      "image": "420943511896.dkr.ecr.eu-west-3.amazonaws.com/mobili-backend-staging:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [],
      "secrets": [
        {
          "name": "DB_URL",
          "valueFrom": "arn:aws:ssm:eu-west-3:420943511896:parameter/mobili/staging/DB_URL"
        },
        {
          "name": "DB_USERNAME",
          "valueFrom": "arn:aws:ssm:eu-west-3:420943511896:parameter/mobili/staging/DB_USERNAME"
        },
        {
          "name": "DB_PASSWORD",
          "valueFrom": "arn:aws:ssm:eu-west-3:420943511896:parameter/mobili/staging/DB_PASSWORD"
        },
        {
          "name": "SPRING_PROFILES_ACTIVE",
          "valueFrom": "arn:aws:ssm:eu-west-3:420943511896:parameter/mobili/staging/SPRING_PROFILES_ACTIVE"
        },
        {
          "name": "JWT_SECRET",
          "valueFrom": "arn:aws:ssm:eu-west-3:420943511896:parameter/mobili/staging/JWT_SECRET"
        },
        {
          "name": "FEDAPAY_SECRET_KEY",
          "valueFrom": "arn:aws:ssm:eu-west-3:420943511896:parameter/mobili/staging/FEDAPAY_SECRET_KEY"
        },
        {
          "name": "FEDAPAY_WEBHOOK_SECRET",
          "valueFrom": "arn:aws:ssm:eu-west-3:420943511896:parameter/mobili/staging/FEDAPAY_WEBHOOK_SECRET"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/td-mobili-backend-staging",
          "awslogs-region": "eu-west-3",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ],
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  }
}