# Copier vers .env à la racine du dépôt — ne pas commiter .env
#   copy .env.example .env   (Windows)   |   cp .env.example .env   (Unix)
#
# Maven (mobili-boot) et le bootstrap dotenv remontent les parents pour charger ce fichier.

SPRING_PROFILES_ACTIVE=dev

JWT_SECRET=

FEDAPAY_SECRET_KEY=
FEDAPAY_WEBHOOK_SECRET=

# Postgres local — aligné sur application.yml (localhost:5432/mobili_db par défaut)
DB_USERNAME=postgres
DB_PASSWORD=mobili
