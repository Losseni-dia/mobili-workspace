# Copier vers .env à la racine du dépôt (à côté de docker-compose.yml) — ne pas commiter .env
#   copy .env.example .env   (Windows)   |   cp .env.example .env   (Unix)
#
# Docker Compose charge ce fichier automatiquement. Maven (backend) lit aussi ce fichier via la recherche parent .env.

SPRING_PROFILES_ACTIVE=dev

JWT_SECRET=

FEDAPAY_SECRET_KEY=
FEDAPAY_WEBHOOK_SECRET=

# --- Postgres WINDOWS (Maven + Grafana) — aligné sur application.yml (localhost:5432/mobili_db) ---
DB_USERNAME=postgres
DB_PASSWORD=mobili

# Postgres du COMPOSE sur le port hôte 5433 : libère 5432 pour Postgres Windows (sinon Grafana voit le mauvais serveur).
POSTGRES_PORT=5433

# Grafana (docker compose --profile metrics) → Postgres Windows (mobili_db). Reprend DB_* par défaut.
GRAFANA_POSTGRES_URL=host.docker.internal:5432
GRAFANA_POSTGRES_DB=mobili_db
# Si erreur pq « authentification par mot de passe échouée pour l'utilisateur postgres » : le mot de passe
# Windows du rôle postgres ≠ DB_PASSWORD. Soit ALTER USER postgres … pour aligner, soit surcharges ci‑dessous :
# GRAFANA_POSTGRES_USER=postgres
# GRAFANA_POSTGRES_PASSWORD=le_mot_de_passe_réel_postgres_windows

# Mot de passe pour créer grafana_ro au premier init du volume Postgres Docker (voir deploy/postgres/init)
GRAFANA_RO_PASSWORD=grafana_ro_dev

# Optionnel — ports hôte (défauts : API 8081, Prometheus 9090, Grafana 3000, Redis 6379 avec profil redis)
# API_PORT=8081
# PROMETHEUS_PORT=9090
# GRAFANA_PORT=3000
# REDIS_PORT=6379
# GF_SECURITY_ADMIN_USER / GF_SECURITY_ADMIN_PASSWORD via GRAFANA_ADMIN_USER / GRAFANA_ADMIN_PASSWORD dans compose

# Alternative : Grafana sur la base « mobili » dans le Postgres Docker (réseau Docker), pas mobili_db Windows :
# GRAFANA_POSTGRES_URL=postgres:5432
# GRAFANA_POSTGRES_DB=mobili
# GRAFANA_POSTGRES_USER=mobili
# GRAFANA_POSTGRES_PASSWORD=mobili
